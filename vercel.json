{
  "rewrites": [
    { "source": "/g/:code", "destination": "/gate.html" },
    { "source": "/admin/findings", "destination": "/api/admin/panel" }
  ],
  "headers": [
    {
      "source": "/poems.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }
      ]
    },
    {
      "source": "/poems.html.bak",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }
      ]
    },
    {
      "source": "/poems_:variant.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }
      ]
    }
  ]
}
